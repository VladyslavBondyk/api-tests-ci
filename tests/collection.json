{
  "info": {
    "_postman_id": "40af1140-29a1-4505-bd7c-87a80ea67de3",
    "name": "NASA Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "28052532",
    "_collection_link": "https://go.postman.co/collection/28052532-40af1140-29a1-4505-bd7c-87a80ea67de3?source=collection_link"
  },
  "item": [
    {
      "name": "pic_of_theYear",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const template = `",
              "<h2>NASA APOD</h2>",
              "<table>",
              "{{#each rows}}",
              "<tr><td>{{field}}</td><td>{{value}}</td></tr>",
              "{{/each}}",
              "</table>",
              "`;",
              "",
              "function createPayload() {",
              "  const data = pm.response.json();",
              "  const rows = Object.entries(data).map(([key, val]) => ({",
              "    field: key,",
              "    value: val",
              "  }));",
              "  return { rows };",
              "}",
              "",
              "pm.visualizer.set(template, createPayload());"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "https://api.nasa.gov/planetary/apod?api_key={{API_KEY}}",
        "description": "NASA APOD request"
      },
      "response": []
    },
    {
      "name": "APOD basic test",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "https://api.nasa.gov/planetary/apod?api_key={{API_KEY}}",
        "description": "Basic APOD call"
      },
      "response": []
    }
  ]
}
